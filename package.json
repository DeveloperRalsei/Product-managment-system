        "dev": "concurrently \"npm run client:dev*\" \"npm run server:dev\""
    },
    "workspaces": [
        "apps/*"
    ],
    "dependencies": {
        "@mantine/form": "^7.17.2",
        "@mantine/notifications": "^7.17.2",
        "concurrently": "^9.0.1",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "typescript": "^5.8.2",
        "zod": "^3.24.2"
    }
}
